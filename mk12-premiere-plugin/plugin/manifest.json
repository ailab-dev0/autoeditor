{
  "id": "mk12.editorlens.v2",
  "name": "EditorLens",
  "version": "2.0.0",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entryPoints": [
    {
      "type": "panel",
      "id": "editorlens.main",
      "label": "EditorLens",
      "mainPath": "panels/main/index.html",
      "script": "panels/main/index.js",
      "minimumSize": { "width": 300, "height": 400 },
      "preferredDockedSize": { "width": 450, "height": 800 },
      "icons": [
        { "width": 23, "height": 23, "path": "icons/icon_D.png", "scale": [1], "theme": ["darkest", "dark"] },
        { "width": 23, "height": 23, "path": "icons/icon_N.png", "scale": [1], "theme": ["lightest", "light"] },
        { "width": 23, "height": 23, "path": "icons/icon_D@2x.png", "scale": [2], "theme": ["darkest", "dark"] },
        { "width": 23, "height": 23, "path": "icons/icon_N@2x.png", "scale": [2], "theme": ["lightest", "light"] }
      ]
    },
    {
      "type": "panel",
      "id": "editorlens.stock",
      "label": "EditorLens Stock",
      "mainPath": "panels/stock/index.html",
      "script": "panels/stock/index.js",
      "minimumSize": { "width": 300, "height": 300 },
      "preferredDockedSize": { "width": 400, "height": 600 }
    },
    {
      "type": "panel",
      "id": "editorlens.transcript",
      "label": "EditorLens Transcript",
      "mainPath": "panels/transcript/index.html",
      "script": "panels/transcript/index.js",
      "minimumSize": { "width": 300, "height": 300 },
      "preferredDockedSize": { "width": 400, "height": 600 }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "http://localhost:8000",
        "http://localhost:8001",
        "ws://localhost:8000",
        "ws://localhost:8001",
        "https://api.pexels.com",
        "https://pixabay.com",
        "https://fal.run",
        "https://openrouter.ai",
        "https://speechmatics.com"
      ]
    },
    "localFileSystem": "fullAccess",
    "allowCodeGenerationFromStrings": true,
    "launchProcess": {
      "extensions": [".mp4", ".mov", ".wav", ".mp3", ".aac", ".png", ".jpg", ".jpeg"]
    }
  }
}
