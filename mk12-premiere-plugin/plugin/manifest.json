{
  "id": "mk12.editorlens.v2",
  "name": "EditorLens",
  "version": "2.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entryPoints": [
    {
      "type": "panel",
      "id": "editorlens.main",
      "label": "EditorLens",
      "minimumSize": { "width": 640, "height": 360 },
      "preferredDockedSize": { "width": 1024, "height": 576 },
      "preferredFloatingSize": { "width": 1024, "height": 576 },
      "icons": [
        { "width": 32, "height": 32, "path": "icons/icon_D.png", "scale": [1, 2], "theme": ["dark", "darkest"], "species": ["generic"] },
        { "width": 32, "height": 32, "path": "icons/icon_N.png", "scale": [1, 2], "theme": ["lightest", "light"], "species": ["generic"] }
      ]
    },
    {
      "type": "panel",
      "id": "editorlens.stock",
      "label": "EditorLens Stock",
      "minimumSize": { "width": 640, "height": 360 },
      "preferredDockedSize": { "width": 1024, "height": 576 },
      "preferredFloatingSize": { "width": 1024, "height": 576 }
    },
    {
      "type": "panel",
      "id": "editorlens.transcript",
      "label": "EditorLens Transcript",
      "minimumSize": { "width": 640, "height": 360 },
      "preferredDockedSize": { "width": 1024, "height": 576 },
      "preferredFloatingSize": { "width": 1024, "height": 576 }
    }
  ],
  "icons": [
    { "width": 32, "height": 32, "path": "icons/icon_D.png", "scale": [1, 2], "theme": ["dark", "darkest"], "species": ["generic"] },
    { "width": 32, "height": 32, "path": "icons/icon_N.png", "scale": [1, 2], "theme": ["lightest", "light"], "species": ["generic"] }
  ],
  "requiredPermissions": {
    "allowCodeGenerationFromStrings": true,
    "network": {
      "domains": [
        "http://localhost:8000",
        "http://localhost:8001",
        "ws://localhost:8000",
        "ws://localhost:8001",
        "https://api.pexels.com",
        "https://pixabay.com",
        "https://fal.run",
        "https://openrouter.ai",
        "https://speechmatics.com"
      ]
    },
    "localFileSystem": "fullAccess",
    "launchProcess": {
      "schemes": ["http", "https"],
      "extensions": [".mp4", ".mov", ".mkv", ".avi", ".webm"]
    }
  }
}
