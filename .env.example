# ─────────────────────────────────────────────
# EditorLens MK-12 — Environment Variables
# ─────────────────────────────────────────────

# Backend Server
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres (Neon — required for auth/projects)
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# MinIO / S3 (required for pipeline artifacts)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=editorlens
MINIO_REGION=us-east-1

# AI (OpenRouter — powers content analysis + blueprint decisions)
OPENROUTER_API_KEY=sk-or-v1-...

# Transcription (AssemblyAI — primary engine)
ASSEMBLYAI_API_KEY=...

# Tool paths (local dev)
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# Dashboard (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Animation Engine
ANIMATION_ENGINE_URL=http://localhost:4200
ANIMATION_PORT=4200

# Stock Footage (optional — Pexels is free)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Image Generation (optional — fal.ai)
FAL_KEY=

# CORS — add your WiFi IP for network access
CORS_ORIGINS=http://localhost:3000,http://192.168.1.0/24

# JWT Secret (generate a random string)
JWT_SECRET=change-me-in-production
